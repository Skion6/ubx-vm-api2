{
    # Replace this with your actual email
    email your-email@example.com

    # This tells Caddy to check with your app before getting an SSL cert
    on_demand_tls {
        ask http://10.0.0.2:8000/api/health
    }
}

# Catch-all for HTTP (80) and HTTPS (443)
:80, :443 {
    tls {
        on_demand
    }

    reverse_proxy 10.0.0.2:8000 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
}