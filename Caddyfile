# --- MAIN SECURE SERVER ---
ec2-18-219-58-159.us-east-2.compute.amazonaws.com {
    encode gzip

    # API Traffic — everything under /api/* goes to the FastAPI backend
    handle /api/* {
        reverse_proxy localhost:8000 {
            lb_try_duration 5s
            lb_try_interval 250ms
            
            health_uri /api/health
            health_interval 10s
            health_timeout 2s
        }
    }

    # Default handler for anything else
    handle {
        respond "Not found" 404
    }

    log {
        output file /var/log/caddy/access.log
    }
}
