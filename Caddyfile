# --- MAIN SECURE SERVER ---
ec2-18-219-58-159.us-east-2.compute.amazonaws.com {
    encode gzip

    # API Traffic — everything under /api/* goes to the FastAPI backend
    handle /api/* {
        reverse_proxy localhost:8000
    }

    # Default handler for anything else
    handle {
        respond "Not found" 404
    }

    log {
        output file /var/log/caddy/access.log
    }
}
