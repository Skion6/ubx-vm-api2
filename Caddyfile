{
    email eastondean195@gmail.com

    # ON-DEMAND TLS CONFIGURATION
    on_demand_tls {
        # IMPORTANT: Make sure your FastAPI has this GET endpoint!
        ask http://localhost:8000/api/health
    }
}

# --- DYNAMIC MULTI-DOMAIN SERVER BLOCK ---
:443 {
    encode gzip

    tls {
        on_demand
    }

    # 1. Route ALL traffic to your FastAPI backend (including the root /)
    # This ensures your API and any frontend served by FastAPI works.
    handle {
        reverse_proxy localhost:8000 {
            lb_try_duration 5s
            lb_try_interval 250ms
            
            health_uri /api/health
            health_interval 10s
            health_timeout 2s
        }
    }

    # 2. (Optional) Custom Logging
    log {
        output file /var/log/caddy/access.log
    }
}